font-size = 13
font-family = VictorMono NFM
theme = NvimDark
font-thicken = true
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true
adjust-cell-height = 5%
background-opacity = 0.75
background-blur-radius = 70
mouse-hide-while-typing = true
window-save-state = always
window-new-tab-position = current
window-colorspace = "display-p3"
background = #000000
# foreground = #ffffff

# macOS-specific settings
macos-titlebar-style = tabs
macos-option-as-alt = true

# window controls
confirm-close-surface = true
window-title-font-family = VictorMono NFM Italic
window-decoration = true
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-save-state = always

# extras
shell-integration-features = true
copy-on-select = clipboard
focus-follows-mouse = true
link-url = true

# custom keybindings
keybind = cmd+i=inspector:toggle
keybind = cmd+f=toggle_fullscreen
keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab

# tab navigation
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7

# splits
keybind = cmd+s>v=new_split:right
keybind = cmd+s>d=new_split:down
keybind = cmd+e=equalize_splits

# split navigation 
keybind = cmd+left=goto_split:left
keybind = cmd+down=goto_split:bottom
keybind = cmd+up=goto_split:top
keybind = cmd+right=goto_split:right
